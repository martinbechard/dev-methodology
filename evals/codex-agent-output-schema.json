{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dev-methodology-codex-agent-output-v1",
  "title": "Dev Methodology Codex Evaluation Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "artifacts",
    "verification"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "blocked",
        "failed"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command",
          "outcome"
        ],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "outcome": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "not-run"
            ]
          }
        }
      }
    }
  }
}
